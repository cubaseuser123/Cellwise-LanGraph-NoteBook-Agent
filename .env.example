# ── AI Provider ──────────────────────────────────────────────────────────────
# Set BASE_URL + API_KEY for any OpenAI-compatible provider.
# See README > Provider Setup for a full list of examples.
VERCEL_AI_GATEWAY_URL=https://api.openai.com/v1
VERCEL_AI_GATEWAY_API_KEY=your_api_key_here

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=1000

# ── Context ───────────────────────────────────────────────────────────────────
MAX_CONTEXT_CELLS=5
MAX_CELL_LENGTH=2000

# ── Project Path (REQUIRED for the IPython startup script) ───────────────────
# Set this to the absolute path of the cloned repository on your machine.
# Examples:
#   Linux/macOS:  NOTEBOOK_AGENT_PATH=/home/yourname/Notebook_Agent
#   Windows:      NOTEBOOK_AGENT_PATH=C:\Users\yourname\Notebook_Agent
NOTEBOOK_AGENT_PATH=/absolute/path/to/Notebook_Agent
